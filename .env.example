# Resend Configuration (for sending invoices)
RESEND_API_KEY=re_your_api_key_here
# Use 'onboarding@resend.dev' for testing, or your verified domain email for production
RESEND_FROM_EMAIL=onboarding@resend.dev

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API (optional - enables AI-enhanced brief analysis)
ANTHROPIC_API_KEY=your-api-key

# Session Configuration (optional - for future cookie signing)
# SESSION_SECRET=generate-a-random-string-here
